# ── Database (Docker Compose + Spring Boot) ──────────────
# These values must match between Docker and Spring Boot.
# The defaults below match application.yml so everything
# works without exporting environment variables.
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=mfhe_db
MYSQL_USER=mfhe_user
MYSQL_PASSWORD=mfhe_pass
MYSQL_HOST_PORT=3307

# ── Spring Boot ──────────────────────────────────────────
# Only needed if you want to override application.yml defaults.
# DB_URL=jdbc:mysql://localhost:3307/mfhe_db
# DB_USER=mfhe_user
# DB_PASSWORD=mfhe_pass
# SERVER_PORT=8080
# JPA_DDL_AUTO=update

# ── CORS ─────────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:5173

# ── Admin API key (leave empty to disable protection) ────
# ADMIN_API_KEY=
